---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Software Developer Portfolio',
	description = 'Single-page software developer portfolio built with Astro.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#111318" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	:root {
		color-scheme: light;
	}

	* {
		box-sizing: border-box;
	}

	html {
		margin: 0;
		min-height: 100%;
		scroll-behavior: smooth;
		background: #f4efe8;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background: #f4efe8;
		color: #111318;
	}

	a {
		color: inherit;
	}

	img {
		display: block;
		max-width: 100%;
	}
	
	button,
	input,
	textarea,
	select {
		font: inherit;
	}
</style>
